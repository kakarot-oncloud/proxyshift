{
  "manifest_version": 2,
  "name": "ProxyShift",
  "version": "1.0.0",
  "description": "Connect to any proxy (HTTP/HTTPS/SOCKS4/SOCKS5), spoof timezone, and stay undetectable. Supports profiles, rotation, and anti-fingerprinting.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "ProxyShift"
  },
  "background": {
    "scripts": ["background/service-worker.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/anti-detect.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_page": "options/options.html",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "webNavigation",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "proxyshift@extension",
      "strict_min_version": "91.0"
    }
  }
}
